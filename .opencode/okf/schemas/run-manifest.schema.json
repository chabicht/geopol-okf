{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OKF lifecycle run manifest",
  "type": "object",
  "required": ["schema_version", "run_id", "baseline_hash", "sources", "model", "claims", "destinations", "worker_write_sets", "pre_edit_hashes", "result_hashes", "validation_delta", "lifecycle_status"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string"},
    "baseline_hash": {"type": "string"},
    "sources": {"type": "array", "items": {"type": "object", "required": ["path", "sha256"]}},
    "model": {"type": "object", "required": ["id", "variant", "vision"]},
    "claims": {"type": "array", "items": {"type": "object", "required": ["id", "source", "facets"]}},
    "destinations": {"type": "array"},
    "worker_write_sets": {"type": "object"},
    "pre_edit_hashes": {"type": "object"},
    "result_hashes": {"type": "object"},
    "validation_delta": {"type": "object"},
    "lifecycle_status": {"type": "string"}
  }
}
